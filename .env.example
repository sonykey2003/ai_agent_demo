# ---- Provider selection -------------------------------------------------
# openai | nim | local
LLM_PROVIDER=local
TEMPERATURE=0.2
# Cap response length (stops runaway/looping generations).
MAX_TOKENS=1024
# Penalty to discourage repetition loops (0 disables).
FREQUENCY_PENALTY=0.3

# ---- OpenAI -------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- NVIDIA NIM (hosted catalog or self-hosted microservice) ------------
NVIDIA_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=deepseek-ai/deepseek-r1

# ---- Local tiny model via Ollama ----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=qwen2.5:0.5b

# ---- Vendor-neutral OpenTelemetry ---------------------------------------
# App always exports to a local Collector; the Collector decides the backend(s).
# Set TELEMETRY_ENABLED=false for bare local runs without a Collector.
TELEMETRY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agent-chat-demo
DEPLOYMENT_ENVIRONMENT=demo

# ---- Galileo backend (read by the OTel Collector, not the app) ----------
# The Collector routes the app's OpenInference spans to Galileo. Get a key from
# your Galileo console: Settings -> API Keys.
GALILEO_API_KEY=<your_api_key>
GALILEO_PROJECT=<your_project_name>
GALILEO_LOG_STREAM=default
# OTLP ingest URL = your console host with `console`->`api`, then /otel/traces:
#   default cloud      ->  https://api.galileo.ai/otel/traces
#   multitenant cloud  ->  https://api.multitenant.galileocloud.io/otel/traces
GALILEO_OTEL_ENDPOINT=https://api.galileo.ai/otel/traces

# ---- Galileo metric-setup helper only (eval/configure_galileo_metrics.py) -----
# These are NOT read by the app or the Collector. They let the helper script
# register custom RAG judge metrics scored by your own model, because Galileo's
# built-in RAG metrics are pinned to the gpt-4.1-mini scorer (needs OpenAI).
# Console URL of your Galileo tenant (used by the Galileo SDK):
#   default cloud      ->  https://app.galileo.ai
#   multitenant cloud  ->  https://console.multitenant.galileocloud.io
GALILEO_CONSOLE_URL=https://app.galileo.ai
# Exact model alias to use as the metric judge (from Settings -> Integrations):
GALILEO_JUDGE_MODEL=moonshotai/kimi-k2.6
